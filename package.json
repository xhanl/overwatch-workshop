{
  "icon": "images/extension/icon.png",
  "name": "overwatch-workshop",
  "displayName": "Overwatch Workshop",
  "publisher": "Xcrystal",
  "description": "守望先锋® 工坊语言支持（中文）",
  "repository": {
    "url": "https://github.com/XHanL/overwatch-workshop"
  },
  "keywords": [
    "ow",
    "overwatch",
    "workshop",
    "守望先锋",
    "工坊"
  ],
  "version": "3.7.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ow",
        "aliases": [
          "OW",
          "ow"
        ],
        "extensions": [
          ".ow",
          ".owl",
          ".watch"
        ],
        "configuration": "ow.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ow",
        "scopeName": "source.ow",
        "path": "./syntaxes/ow.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ow.command.newFile",
        "title": "OW 文件"
      },
      {
        "command": "ow.command.suggest",
        "title": "展开"
      },
      {
        "command": "ow.command.lineBreak",
        "title": "换行"
      },
      {
        "command": "ow.command.obfuscate",
        "title": "混淆"
      },
      {
        "command": "ow.command.export",
        "title": "导出"
      },
      {
        "command": "ow.command.import",
        "title": "导入"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "manualView",
          "title": "OW",
          "icon": "images/extension/manual.svg"
        }
      ]
    },
    "views": {
      "manualView": [
        {
          "id": "ow.view.manual",
          "name": "参考手册",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "file/newFile": [
        {
          "command": "ow.command.newFile"
        }
      ],
      "editor/title": [
        {
          "command": "ow.command.suggest",
          "when": "editorLangId == ow",
          "group": "navigation@100"
        },
        {
          "command": "ow.command.lineBreak",
          "when": "editorLangId == ow",
          "group": "navigation@101"
        },
        {
          "command": "ow.command.obfuscate",
          "when": "editorLangId == ow",
          "group": "navigation@102"
        },
        {
          "command": "ow.command.export",
          "when": "editorLangId == ow",
          "group": "navigation@103"
        },
        {
          "command": "ow.command.import",
          "when": "editorLangId == ow",
          "group": "navigation@104"
        }
      ],
      "editor/context": [
        {
          "command": "ow.command.suggest",
          "when": "editorLangId == ow",
          "group": "0@0"
        },
        {
          "command": "ow.command.lineBreak",
          "when": "editorLangId == ow",
          "group": "0@1"
        },
        {
          "command": "ow.command.obfuscate",
          "when": "editorLangId == ow",
          "group": "0@2"
        },
        {
          "command": "ow.command.export",
          "when": "editorLangId == ow",
          "group": "0@3"
        },
        {
          "command": "ow.command.import",
          "when": "editorLangId == ow",
          "group": "0@4"
        }
      ]
    },
    "themes": [
      {
        "label": "Overwatch Workshop 深邃",
        "uiTheme": "vs-dark",
        "path": "themes/ow.dark.json"
      },
      {
        "label": "Overwatch Workshop 静谧",
        "uiTheme": "vs-dark",
        "path": "themes/ow.gray.json"
      },
      {
        "label": "Overwatch Workshop 深井",
        "uiTheme": "vs-dark",
        "path": "themes/ow.deep.TaZu.json"
      },
      {
        "label": "Overwatch Workshop 明亮",
        "uiTheme": "vs",
        "path": "themes/ow.light.json"
      }
    ]
  },
  "scripts": {
    "test": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/extensionTests.js",
    "pretest": "npm run compile-web",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "npm run check-types && npm run lint && node esbuild.js",
    "watch-web": "npm-run-all -p watch-web:*",
    "watch-web:esbuild": "node esbuild.js --watch",
    "watch-web:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package-web": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "run-in-browser": "npm run compile-web && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@types/assert": "^1.5.10",
    "@types/mocha": "^10.0.7",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-web": "^0.0.55",
    "assert": "^2.1.0",
    "esbuild": "^0.21.5",
    "esbuild-copy-static-files": "^0.1.0",
    "eslint": "^8.57.0",
    "glob": "^10.4.2",
    "mocha": "^10.5.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  }
}
